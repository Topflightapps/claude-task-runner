# ClickUp
CLICKUP_API_TOKEN=pk_...
CLICKUP_TEAM_ID=
CLICKUP_CLAUDE_USER_ID=
CLICKUP_REPO_FIELD_ID=
WEBHOOK_SECRET=
WEBHOOK_PORT=3000

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_PR_ASSIGNEE=your-github-username

# GitHub PR Review Pipeline (optional — enabled when GITHUB_WEBHOOK_SECRET + GITHUB_USERNAME are set)
GITHUB_WEBHOOK_SECRET=
GITHUB_USERNAME=
REVIEW_TIMEOUT_MS=900000

# Slack DM notifications (optional — sends you a DM when a review is ready)
SLACK_BOT_TOKEN=xoxb-...
SLACK_USER_ID=

# Runner config
WORK_DIR=/tmp/claude-task-runner/repos
DB_PATH=./data/task-runner.db
CLAUDE_MAX_TURNS=10

# Librarian — cross-task learning (optional — disabled by default)
LIBRARIAN_ENABLED=false
OPENAI_API_KEY=sk-...

# Optional
ANTHROPIC_API_KEY=
FIGMA_MCP_TOKEN=

# Admin panel (optional — leave empty to disable)
ADMIN_PASSWORD=
